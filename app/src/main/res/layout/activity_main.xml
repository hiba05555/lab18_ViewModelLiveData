<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/hc_background"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔢 ViewModel + LiveData"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/hc_primary"
        android:gravity="center"
        android:paddingBottom="32dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="80sp"
            android:textStyle="bold"
            android:textColor="@color/hc_primary"
            android:padding="32dp"/>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tournez l'écran pour tester la persistance !"
        android:textSize="14sp"
        android:textColor="@color/hc_text_dark"
        android:gravity="center"
        android:paddingBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIncrement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ INCRÉMENTER"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/hc_success"
        style="@style/Widget.MaterialComponents.Button"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDecrement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➖ DÉCRÉMENTER"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/hc_primary"
        style="@style/Widget.MaterialComponents.Button"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 RÉINITIALISER"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/hc_error"
        style="@style/Widget.MaterialComponents.Button"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔀 INCRÉMENT BACKGROUND"
        android:backgroundTint="@color/hc_accent"
        style="@style/Widget.MaterialComponents.Button"/>

</LinearLayout>